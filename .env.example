# ============================================================
# 📧 CẤU HÌNH GMAIL (BẮT BUỘC)
# ============================================================
# Email Gmail dùng để GỬI (email của bạn)
GMAIL_USER=your_email@gmail.com

# App Password (KHÔNG phải mật khẩu Gmail thường)
# Cách lấy App Password:
#   1. Vào https://myaccount.google.com/security
#   2. Bật "2-Step Verification" (Xác minh 2 bước)
#   3. Vào https://myaccount.google.com/apppasswords
#   4. Chọn app = "Mail", device = "Windows Computer"
#   5. Copy mật khẩu 16 ký tự (ví dụ: abcd efgh ijkl mnop)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ============================================================
# 📬 DANH SÁCH EMAIL NHẬN (BẮT BUỘC)
# ============================================================
# Gửi cho 1 người:
RECIPIENT_EMAIL=nguoinhan@gmail.com

# Gửi cho NHIỀU người (phân cách bằng dấu phẩy):
# RECIPIENT_EMAIL=nguoi1@gmail.com,nguoi2@gmail.com,nguoi3@gmail.com

# ============================================================
# 🤖 GEMINI AI (TÙY CHỌN - để có tóm tắt + từ vựng AI)
# ============================================================
# Lấy API key miễn phí tại: https://aistudio.google.com/apikey
# Để trống nếu không dùng AI
GEMINI_API_KEY=

# ============================================================
# ⏰ LỊCH GỬI EMAIL (TÙY CHỌN - mặc định 6:30 sáng + 5:30 chiều)
# ============================================================
MORNING_SEND_HOUR=6
MORNING_SEND_MINUTE=30
EVENING_SEND_HOUR=17
EVENING_SEND_MINUTE=30

# Múi giờ Việt Nam
TIMEZONE=Asia/Ho_Chi_Minh
